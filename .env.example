# Supabase — get these from supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (server-side only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret for authenticating agent API calls (POST to /api/articles, /api/newsletters)
# Generate a strong random string, e.g.: openssl rand -hex 32
API_SECRET=your-api-secret
