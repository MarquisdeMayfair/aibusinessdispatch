# Supabase — get these from supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (server-side only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret for authenticating agent API calls (POST to /api/articles, /api/newsletters, /api/images)
# Generate a strong random string, e.g.: openssl rand -hex 32
API_SECRET=your-api-secret

# Vercel Blob — auto-provisioned when you add the Blob store via Vercel dashboard
# Settings > Storage > Create > Blob
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# ---- Automation (Vercel Cron) ----

# Anthropic API key — used by /api/cron/daily-dispatch to write articles via Claude
ANTHROPIC_API_KEY=your-anthropic-api-key

# xAI Grok API key — used for image generation
XAI_API_KEY=your-xai-api-key

# Cron secret — secures the cron endpoints. Generate with: openssl rand -hex 32
# Must also be set in vercel.json or as CRON_SECRET env var
CRON_SECRET=your-cron-secret

# Site URL (used by cron for self-referencing API calls)
NEXT_PUBLIC_SITE_URL=https://aibusinessdispatch.vercel.app
